  "properties": {
    "id": {"type": "string"},
    "operation": {"enum": ["decode", "encode", "roundtrip"]},
    "profile": {"type": "string"},
    "input": {"type": "object"},
    "options": {"type": "object"},
    "expect": {"type": "object"},
    "source": {"type": "object"}
  },
  "additionalProperties": false
}
